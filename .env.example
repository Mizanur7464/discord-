# ============================================
#  Discord Bot Settings (required)
# ============================================
DISCORD_BOT_TOKEN=your_bot_token_here

# Channel(s) on YOUR server the bot watches for news (comma-separated)
NEWS_SOURCE_CHANNEL_IDS=123456789012345678

# Where bot sends trade alerts
ALERT_CHANNEL_ID=123456789012345678

# Optional: where bot posts AI watchlist + monitoring updates
WATCHLIST_CHANNEL_ID=1517059046635470918

# Phase 5: summary rankings channel (buyer creates #summary-channel)
SUMMARY_CHANNEL_ID=123456789012345680

# Raw Benzinga news posts here (replaces NuntioBot news forward)
NEWS_CHANNEL_ID=111111111111111111

# Own scanner volume/RVOL alerts (replaces NuntioBot mosquito forward)
MOSQUITO_CHANNEL_ID=222222222222222222

# High-potential symbols before they become top gainers
POTENTIAL_CHANNEL_ID=333333333333333333

# ============================================
#  Benzinga News via Massive (buyer's $99/mo plan)
# ============================================
MASSIVE_API_KEY=your_massive_api_key_here

# Legacy direct Benzinga key (optional fallback)
# BENZINGA_API_KEY=your_benzinga_api_key_here
# BENZINGA_NEWS_PROVIDER=massive

# ============================================
#  User Session Forwarder (alt Discord account)
# ============================================
# Buyer alt account login
DISCORD_USER_EMAIL=your_alt_email_here
DISCORD_USER_PASSWORD=your_alt_password_here

# User token — get after login (browser DevTools → authorization header)
DISCORD_USER_TOKEN=your_user_token_here

# Optional — NuntioBot forward (disabled; Benzinga feed is primary)
# FORWARD_SOURCE_CHANNEL_IDS=123456789012345678
# FORWARD_CHANNEL_MAP=123456789012345678:111111111111111111
# FORWARD_DEST_CHANNEL_ID=111111111111111111

# ============================================
#  Alpaca Stock Trading (required for auto trade)
# ============================================
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# true = paper trading (test) | false = live trading
ALPACA_PAPER=true

# ============================================
#  OpenAI — AI news sentiment (optional)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
#  Finnhub — short interest data (optional)
# ============================================
FINNHUB_API_KEY=your_finnhub_api_key_here

# ============================================
#  Unusual Whales — options flow API (optional)
# ============================================
UNUSUAL_WHALES_API_KEY=your_unusual_whales_api_key_here
